# ---------------------------------------------------------------------------
# Google Sheets Integration
# ---------------------------------------------------------------------------

# Email address of the Google Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Private key for the service account (copy the full PEM block, keep \n literals)
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINES_HERE\n-----END PRIVATE KEY-----\n"

# The ID found in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
